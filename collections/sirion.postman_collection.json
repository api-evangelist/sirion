    "type": "oauth2",
    "oauth2": [
      { "key": "grant_type", "value": "client_credentials", "type": "string" },
      { "key": "accessTokenUrl", "value": "https://{{tenant}}.sirioncloud.com/oauth/token", "type": "string" },
      { "key": "clientId", "value": "{{clientId}}", "type": "string" },
      { "key": "clientSecret", "value": "{{clientSecret}}", "type": "string" }
    ]
  },
  "variable": [
    { "key": "tenant", "value": "your-org", "type": "string" },
    { "key": "clientId", "value": "", "type": "string" },
    { "key": "clientSecret", "value": "", "type": "string" }
  ],
